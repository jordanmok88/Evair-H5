# Backend API Configuration
# Backend API base URL
VITE_API_BASE_URL=https://evair.zhhwxt.cn/api/v1
# Enable backend API (true/false)
VITE_USE_BACKEND_API=false

# Stripe Publishable Key (frontend use)
# Get yours at https://dashboard.stripe.com/apikeys
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_your_key_here

# eSIM Access (Red Tea) API credentials
# Get yours at https://console.esimaccess.com
ESIM_ACCESS_CODE=your_access_code_here
ESIM_SECRET=your_secret_here

# Supabase (legacy notifications + AI-bot chat fallback)
# Get yours at https://supabase.com > Project Settings > API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Live chat over Laravel Reverb (real-time human-agent chat).
# When VITE_REVERB_APP_KEY is missing the chat falls back to REST polling
# every 4s — useful for staging where Reverb isn't deployed yet.
# - VITE_REVERB_APP_KEY:  REVERB_APP_KEY in Laravel .env (must match exactly)
# - VITE_REVERB_HOST:     hostname WITHOUT scheme, e.g. ws.evairdigital.com
# - VITE_REVERB_PORT:     usually 443 in production (TLS)
# - VITE_REVERB_SCHEME:   "https" forces wss; "http" forces ws (dev only)
VITE_REVERB_APP_KEY=
VITE_REVERB_HOST=
VITE_REVERB_PORT=443
VITE_REVERB_SCHEME=https
