# Backend API Configuration
#
# Leave VITE_API_BASE_URL **unset** for `npm run dev` unless you know you need direct calls —
# the H5 dev server then proxies `/evair-api-proxy/*` → China API (same browser origin), which
# avoids "Network error" on sign-in when testing from a phone at `http://192.168.x.x:3000` (CORS).
#
# Set explicitly for special cases (e.g. hit a different backend):
# VITE_API_BASE_URL=https://evair.zhhwxt.cn/api/v1

# When set to 1, esimApi order/top-up return simulated success (no supplier charge).
# Omit on production Netlify — default is live supplier behaviour.
# VITE_DEMO_ESIM=1

# Stripe Publishable Key (frontend use)
# Get yours at https://dashboard.stripe.com/apikeys
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_your_key_here

# eSIM Access (Red Tea) API credentials
# Get yours at https://console.esimaccess.com
ESIM_ACCESS_CODE=your_access_code_here
ESIM_SECRET=your_secret_here

# Supabase (legacy; optional — some builds still use notifications / tools)
# Chat default routing does NOT pick Supabase; see VITE_CHAT_PROVIDER below.
# Get yours at https://supabase.com > Project Settings > API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ─── Live Chat Provider ─────────────────────────────────────────────
# Which backend powers the support chat UI:
#   auto      – default. Logged in → Laravel (REST; Reverb realtime if env set, else polling).
#              Not logged in → local in-memory only (no server persistence or admin queue).
#   laravel   – force Laravel (+ optional Reverb)
#   supabase  – force Supabase chat (legacy QA only — not used in prod auto path)
#   local     – in-memory demo
# Runtime override: localStorage key `evair-chat-provider`.
VITE_CHAT_PROVIDER=auto

# Reverb (Laravel WebSocket) — values must match Laravel .env (REVERB_APP_KEY / HOST / PORT / SCHEME).
# VITE_REVERB_KEY is used by BOTH services/chat/laravelProvider.ts (pusher-js)
# and services/realtime/echo.ts (laravel-echo / LiveChatView).
# When the key is missing, both paths fall back gracefully (REST polling / no WS).
VITE_REVERB_KEY=
VITE_REVERB_HOST=
VITE_REVERB_PORT=443
VITE_REVERB_SCHEME=https

# Vite dev proxy → edge functions (`/api/*`, `/r`).
# - Netlify: `npx netlify dev` (default :8888) → keep legacy name or unified:
#   VITE_FUNCTIONS_PROXY_TARGET=http://127.0.0.1:8888
# - Cloudflare Pages local: `npm run build && npm run cf:dev` → then:
#   VITE_FUNCTIONS_PROXY_TARGET=http://127.0.0.1:8788
# VITE_NETLIFY_FUNCTIONS_PROXY_TARGET=http://127.0.0.1:8888

# Local Laravel (optional): `vite.config.ts` rewrites `/laravel-api` → this host.
# VITE_LARAVEL_PROXY_TARGET=http://127.0.0.1:8100

# Serverless CORS (`netlify dev` OR Cloudflare `.dev.vars` / Pages secrets): comma-separated Origins,
# e.g. branch deploy + local Vite: ALLOWED_ORIGINS=https://main--evair-h5.netlify.app,http://localhost:3000
# ALLOWED_ORIGINS=

# Do not set GEMINI_API_KEY for the SPA build. Any future LLM must use a serverless function + server-only secret.

# One-off regenerate static carrier map: npm run carriers:pull (not used by Vite runtime)
# ESIM_ACCESS_CODE=
# ESIM_SECRET=
