# Backend API Configuration
# Backend API base URL
VITE_API_BASE_URL=https://evair.zhhwxt.cn/api/v1

# When set to 1, esimApi order/top-up return simulated success (no supplier charge).
# Omit on production Netlify — default is live supplier behaviour.
# VITE_DEMO_ESIM=1

# Stripe Publishable Key (frontend use)
# Get yours at https://dashboard.stripe.com/apikeys
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_your_key_here

# eSIM Access (Red Tea) API credentials
# Get yours at https://console.esimaccess.com
ESIM_ACCESS_CODE=your_access_code_here
ESIM_SECRET=your_secret_here

# Supabase (legacy notifications + AI-bot chat fallback)
# Get yours at https://supabase.com > Project Settings > API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ─── Live Chat Provider ─────────────────────────────────────────────
# Which backend powers the support chat:
#   auto      – default. Logged-in users with Reverb env → laravel; else supabase; else local
#   supabase  – force Supabase Realtime
#   laravel   – force Laravel /api/v1/h5/conversations + Reverb (requires login)
#   local     – in-memory only (AI echo, messages do not persist)
# Runtime override available via localStorage key `evair-chat-provider`.
VITE_CHAT_PROVIDER=auto

# Reverb (Laravel WebSocket) — values must match Laravel .env (REVERB_APP_KEY / HOST / PORT / SCHEME).
# VITE_REVERB_KEY is used by BOTH services/chat/laravelProvider.ts (pusher-js)
# and services/realtime/echo.ts (laravel-echo / LiveChatView).
# When the key is missing, both paths fall back gracefully (REST polling / no WS).
VITE_REVERB_KEY=
VITE_REVERB_HOST=
VITE_REVERB_PORT=443
VITE_REVERB_SCHEME=https

# One-off regenerate static carrier map: npm run carriers:pull (not used by Vite runtime)
# ESIM_ACCESS_CODE=
# ESIM_SECRET=
